---
// Footer.astro — Site footer
const year = new Date().getFullYear();
---
<footer class="bg-gray-50 dark:bg-slate-900 border-t border-gray-200 dark:border-slate-700 mt-16 py-10 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 font-bold text-xl text-gray-900 dark:text-white mb-3">
          <span>⚡</span>
          <span>CLI Tools Guide</span>
        </div>
        <p class="text-gray-500 dark:text-slate-400 text-sm leading-relaxed">
          Practical guides and tips for command-line tools. Level up your terminal workflow.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-3">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="text-gray-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Home</a></li>
          <li><a href="/tools" class="text-gray-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">All Tools</a></li>
          <li><a href="/about" class="text-gray-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">About</a></li>
        </ul>
      </div>

      <!-- Featured Tools -->
      <div>
        <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-3">Featured Tools</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/tools/bat" class="text-gray-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">bat — cat with syntax highlighting</a></li>
          <li><a href="/tools/vim" class="text-gray-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">vim — advanced text editor</a></li>
          <li><a href="/tools/fzf" class="text-gray-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">fzf — fuzzy finder</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-200 dark:border-slate-700 pt-6 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-gray-400 dark:text-slate-500">
      <p>© {year} CLI Tools Guide. All rights reserved.</p>
      <p>Built with <a href="https://astro.build" target="_blank" rel="noopener" class="hover:text-blue-500 transition-colors">Astro</a> &amp; <a href="https://tailwindcss.com" target="_blank" rel="noopener" class="hover:text-blue-500 transition-colors">Tailwind CSS</a>. Deployed on <a href="https://pages.cloudflare.com" target="_blank" rel="noopener" class="hover:text-blue-500 transition-colors">Cloudflare Pages</a>.</p>
    </div>
  </div>
</footer>
