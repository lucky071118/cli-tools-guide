---
// ToolLayout.astro — Layout for individual tool pages with TOC and ad placements
import Layout from './Layout.astro';
import AdBlock from '../components/AdBlock.astro';

export interface Props {
  title: string;
  description: string;
  tool: string;
  /** Table of contents entries */
  toc?: { id: string; text: string; level: number }[];
}

const { title, description, tool, toc = [] } = Astro.props;
---

<Layout title={title} description={description}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb Navigation -->
    <nav aria-label="Breadcrumb" class="mb-6 text-sm text-gray-500 dark:text-slate-400">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Home</a></li>
        <li aria-hidden="true"><span class="mx-1">›</span></li>
        <li><a href="/tools" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Tools</a></li>
        <li aria-hidden="true"><span class="mx-1">›</span></li>
        <li class="text-gray-800 dark:text-slate-200 font-medium" aria-current="page">{tool}</li>
      </ol>
    </nav>

    <!-- AD: Top of tool page — high-visibility placement -->
    <AdBlock slot="top" format="horizontal" />

    <div class="lg:flex lg:gap-8">
      <!-- Table of Contents (desktop sidebar) -->
      {toc.length > 0 && (
        <aside class="hidden lg:block w-64 shrink-0">
          <div class="sticky top-6 bg-gray-50 dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700 p-4">
            <h2 class="font-semibold text-gray-800 dark:text-slate-200 mb-3 text-sm uppercase tracking-wide">
              Table of Contents
            </h2>
            <nav>
              <ul class="space-y-1.5">
                {toc.map((item) => (
                  <li style={`padding-left: ${(item.level - 2) * 12}px`}>
                    <a
                      href={`#${item.id}`}
                      class="block text-sm text-gray-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors py-0.5"
                    >
                      {item.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}

      <!-- Main Content -->
      <div class="flex-1 min-w-0">
        <!-- Mobile TOC -->
        {toc.length > 0 && (
          <details class="lg:hidden mb-6 bg-gray-50 dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700 p-4">
            <summary class="font-semibold text-gray-800 dark:text-slate-200 cursor-pointer text-sm uppercase tracking-wide">
              Table of Contents
            </summary>
            <nav class="mt-3">
              <ul class="space-y-1.5">
                {toc.map((item) => (
                  <li style={`padding-left: ${(item.level - 2) * 12}px`}>
                    <a
                      href={`#${item.id}`}
                      class="block text-sm text-gray-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400"
                    >
                      {item.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </details>
        )}

        <!-- Tool article content injected here -->
        <article class="prose-tool">
          <slot />
        </article>

        <!-- AD: Bottom of tool page -->
        <AdBlock slot="bottom" format="rectangle" />
      </div>
    </div>
  </div>
</Layout>
