---
// src/pages/index.astro — Home page
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import AdBlock from '../components/AdBlock.astro';

// Tool metadata for the featured tools section
const featuredTools = [
  {
    slug: 'bat',
    name: 'bat',
    tagline: 'A cat clone with syntax highlighting',
    description:
      'View source code files in the terminal with beautiful syntax highlighting, Git integration, and automatic paging. A modern replacement for cat.',
    icon: '🦇',
    tags: ['Rust', 'file-viewer', 'syntax-highlighting'],
    installCmd: 'brew install bat',
  },
  {
    slug: 'vim',
    name: 'vim',
    tagline: 'The ubiquitous terminal text editor',
    description:
      'Master the powerful modal text editor found on every Unix system. Speed up your workflow with macros, text objects, and a rich plugin ecosystem.',
    icon: '📝',
    tags: ['C', 'editor', 'modal-editing'],
    installCmd: 'sudo apt install vim',
  },
  {
    slug: 'fzf',
    name: 'fzf',
    tagline: 'A general-purpose fuzzy finder',
    description:
      'Supercharge your terminal with interactive fuzzy search for files, history, processes, Git branches, and anything else that outputs lines.',
    icon: '🔍',
    tags: ['Go', 'search', 'productivity'],
    installCmd: 'brew install fzf',
  },
];
---

<Layout
  title="CLI Tools Guide"
  description="Practical guides, tips, and tricks for modern CLI tools like bat, vim, fzf and more. Master the command line."
>
  <!-- Hero / Header -->
  <Header />

  <!-- AD: Below-hero placement — high visibility for new visitors -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <AdBlock slot="top" format="horizontal" />
  </div>

  <!-- Featured Tools Section -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-3">Featured CLI Tools</h2>
      <p class="text-gray-500 dark:text-slate-400 max-w-xl mx-auto">
        Each guide includes a full introduction, practical tips &amp; tricks, and advanced usage patterns.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {featuredTools.map((tool) => (
        <a href={`/tools/${tool.slug}`} class="tool-card group block">
          <div class="flex items-start gap-4 mb-4">
            <span class="text-4xl" aria-hidden="true">{tool.icon}</span>
            <div>
              <h3 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                {tool.name}
              </h3>
              <p class="text-sm text-gray-500 dark:text-slate-400">{tool.tagline}</p>
            </div>
          </div>
          <p class="text-gray-600 dark:text-slate-300 text-sm leading-relaxed mb-4">
            {tool.description}
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            {tool.tags.map((tag) => (
              <span class="bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-xs font-medium px-2.5 py-0.5 rounded-full">
                {tag}
              </span>
            ))}
          </div>
          <code class="block bg-gray-900 dark:bg-slate-700 text-green-400 text-xs font-mono px-3 py-2 rounded-lg">
            $ {tool.installCmd}
          </code>
        </a>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a href="/tools" class="btn-primary">
        View All Tools →
      </a>
    </div>
  </section>

  <!-- AD: Mid-page placement -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <AdBlock slot="mid" format="rectangle" />
  </div>

  <!-- Why CLI Tools section -->
  <section class="bg-gray-50 dark:bg-slate-800/50 py-16 mt-4">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-10 text-center">Why Master CLI Tools?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { icon: '🚀', title: 'Speed', text: 'CLI tools execute instantly. No GUI loading, no mouse clicks — just pure keyboard-driven efficiency.' },
          { icon: '🤖', title: 'Automation', text: 'Compose CLI tools in scripts to automate repetitive tasks, saving hours every week.' },
          { icon: '🌍', title: 'Anywhere', text: 'SSH into any server and your skills transfer. CLI tools are available on every Unix-like system.' },
          { icon: '🔗', title: 'Composable', text: 'Chain tools together with pipes. The Unix philosophy: small tools that do one thing well.' },
          { icon: '📊', title: 'Powerful', text: 'One grep or awk command can do what takes minutes in a spreadsheet or GUI application.' },
          { icon: '💡', title: 'Learning', text: 'Understanding CLI tools gives you deep insight into how your system and applications actually work.' },
        ].map((item) => (
          <div class="flex gap-4">
            <span class="text-3xl shrink-0" aria-hidden="true">{item.icon}</span>
            <div>
              <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-1">{item.title}</h3>
              <p class="text-gray-500 dark:text-slate-400 text-sm leading-relaxed">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AD: Bottom page placement -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <AdBlock slot="bottom" format="horizontal" />
  </div>
</Layout>
