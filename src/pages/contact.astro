---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Contact CLI Tools Guide — get in touch for corrections, feedback, or partnership.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav aria-label="Breadcrumb" class="mb-6 text-sm text-gray-500 dark:text-slate-400">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-blue-600 dark:hover:text-blue-400">Home</a></li>
        <li><span class="mx-1">›</span></li>
        <li class="text-gray-800 dark:text-slate-200 font-medium" aria-current="page">Contact</li>
      </ol>
    </nav>

    <h1 class="text-3xl font-bold mb-4">Contact</h1>
    <p class="mb-4">For site corrections, privacy questions, or partnership inquiries, please reach out:</p>

    <ul class="prose-tool mb-6">
      <li>Email: <a href="mailto:lucky071118@gmail.com">lucky071118@gmail.com</a></li>
      <li>GitHub: <a href="https://github.com/lucky071118/cli-tools-guide" target="_blank" rel="noopener">lucky071118/cli-tools-guide</a></li>
    </ul>

    <p>If you found incorrect commands or outdated instructions, please open an issue or submit a PR on GitHub for the fastest resolution.</p>
  </div>
</Layout>
